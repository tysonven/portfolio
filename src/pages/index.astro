---
import { getCollection } from 'astro:content';
const allStudies = await getCollection('case-studies');
const published = allStudies.filter(s => s.data.status === 'published');
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Flow Os — Work</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, sans-serif; background: #f9f9f9; color: #111; }
    header { background: #1600A3; color: white; padding: 40px; }
    header h1 { font-size: 2rem; }
    header p { margin-top: 8px; opacity: 0.8; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; padding: 40px; max-width: 1200px; margin: 0 auto; }
    .card { background: white; border-radius: 8px; padding: 28px; border: 1px solid #e0e0e0; text-decoration: none; color: inherit; display: block; transition: box-shadow 0.2s; }
    .card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
    .card .date { font-size: 0.75rem; color: #999; text-transform: uppercase; letter-spacing: 0.1em; }
    .card h2 { font-size: 1.1rem; margin: 8px 0; color: #1600A3; }
    .card .client { font-size: 0.85rem; color: #666; margin-bottom: 12px; }
    .card p { font-size: 0.9rem; line-height: 1.5; color: #444; }
    .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 16px; }
    .tag { background: #EEF2FF; color: #1600A3; font-size: 0.7rem; padding: 3px 8px; border-radius: 4px; }
  </style>
</head>
<body>
  <header>
    <h1>Flow Os — Work</h1>
    <p>AI systems, automation, and client builds by Tyson Venables</p>
  </header>
  <div class="grid">
    {published.map(study => (
      <a class="card" href={`/case-studies/${study.data.slug}`}>
        <div class="date">{study.data.date} · {study.data.category}</div>
        <h2>{study.data.title}</h2>
        <div class="client">{study.data.client}</div>
        <p>{study.data.excerpt}</p>
        <div class="tags">
          {study.data.tags.slice(0, 4).map(tag => <span class="tag">{tag}</span>)}
        </div>
      </a>
    ))}
  </div>
</body>
</html>
