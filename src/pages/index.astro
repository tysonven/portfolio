---
import { getCollection } from 'astro:content';
import CaseStudy from '../layouts/CaseStudy.astro';

const allPosts = await getCollection('case-studies', ({ data }) => {
  return data.status === 'published';
});

// Sort by date descending, featured first
const posts = allPosts.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return b.data.date.localeCompare(a.data.date);
});

// Category labels
const categoryLabel: Record<string, string> = {
  'flow-os':   'Flow OS',
  'sproutcode': 'SproutCode',
  'internal':  'Internal',
  'winery':    'Winery',
  'personal':  'Personal',
};
---

<CaseStudy
  title="Tyson Venables — Flow OS Builds"
  description="AI systems, automation, and client builds by Tyson Venables. Case studies covering GoHighLevel, Claude AI, n8n automation, and more."
>
  <div class="container">

    <!-- Hero -->
    <section class="hero fade-up">
      <p class="hero-eyebrow">Selected Work</p>
      <h1 class="hero-title">AI systems &amp; automation<br/>built to run.</h1>
      <p class="hero-sub">
        Case studies from Flow OS client builds, SproutCode, and internal tools —
        covering Claude AI, GoHighLevel, n8n, and the systems that tie them together.
      </p>
    </section>

    <!-- Case study grid -->
    <section class="grid fade-up fade-up-delay-1">
      {posts.length === 0 ? (
        <p class="empty">No published case studies yet.</p>
      ) : (
        posts.map(post => (
          <a href={`/case-studies/${post.data.slug}`} class="card">
            <div class="card-top">
              <div class="card-meta">
                <span class="card-date">{post.data.date}</span>
                <span class="tag">{categoryLabel[post.data.category] ?? post.data.category}</span>
                {post.data.featured && <span class="featured-badge">Featured</span>}
              </div>
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-client">{post.data.client}</p>
              <p class="card-excerpt">{post.data.excerpt}</p>
            </div>
            <div class="card-bottom">
              <div class="card-tags">
                {post.data.tags.slice(0, 4).map(tag => (
                  <span class="card-tag">{tag}</span>
                ))}
              </div>
              <span class="card-arrow">→</span>
            </div>
          </a>
        ))
      )}
    </section>

  </div>
</CaseStudy>

<style>
  /* ── Hero ── */
  .hero {
    padding: 5rem 0 3.5rem;
    border-bottom: 1px solid var(--bg-border);
    margin-bottom: 3.5rem;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: var(--text-dim);
    max-width: 520px;
    line-height: 1.65;
    font-weight: 300;
  }

  /* ── Grid ── */
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin-bottom: 6rem;
  }

  .empty {
    color: var(--muted);
    font-size: 0.9375rem;
    padding: 3rem 0;
  }

  /* ── Card ── */
  .card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--bg-border);
    color: var(--text);
    text-decoration: none;
    position: relative;
    transition: padding-left 0.2s ease;
  }

  /* The signature teal left-border that grows on hover */
  .card::before {
    content: '';
    position: absolute;
    left: -clamp(1.5rem, 5vw, 3rem);
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--teal);
    opacity: 0;
    transform: scaleY(0.3);
    transition: opacity 0.2s ease, transform 0.25s ease;
    transform-origin: center;
  }

  .card:hover::before {
    opacity: 1;
    transform: scaleY(1);
  }

  .card:hover .card-title {
    color: var(--coral);
  }

  .card:hover .card-arrow {
    transform: translateX(4px);
    color: var(--coral);
  }

  /* Card meta row */
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .card-date {
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    font-weight: 400;
  }

  .featured-badge {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--coral);
    background: rgba(232, 116, 97, 0.08);
    border: 1px solid rgba(232, 116, 97, 0.3);
    border-radius: var(--radius);
    padding: 0.2em 0.6em;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 0.3rem;
    transition: color 0.2s ease;
  }

  .card-client {
    font-size: 0.8125rem;
    color: var(--muted);
    margin-bottom: 0.75rem;
    font-weight: 400;
  }

  .card-excerpt {
    font-size: 0.9375rem;
    color: var(--text-dim);
    line-height: 1.6;
    font-weight: 300;
    max-width: 600px;
  }

  /* Card bottom row */
  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .card-tag {
    font-size: 0.6875rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .card-tag + .card-tag::before {
    content: '·';
    margin-right: 0.4rem;
  }

  .card-arrow {
    font-size: 1rem;
    color: var(--muted);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  /* ── Responsive ── */
  @media (min-width: 640px) {
    .card {
      flex-direction: row;
      gap: 2rem;
    }

    .card-top { flex: 1; }
    .card-bottom { flex-direction: column; align-items: flex-end; gap: 1rem; min-width: 120px; }
    .card-tags { flex-direction: column; align-items: flex-end; }
    .card-tag + .card-tag::before { content: ''; margin: 0; }
  }
</style>
